# skysplat2roblox — environment variables
# Copy to .env and fill in your values

# Roblox Open Cloud API key (create at https://create.roblox.com/credentials)
# Required scope: universe-places:write
ROBLOX_API_KEY=

# Find these in the URL at create.roblox.com/dashboard/creations
# Example URL: roblox.com/games/1234567890/my-game
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=
